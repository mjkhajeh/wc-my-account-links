msgstr "https://wordpress.org/plugins/my-account-links/"

#: my-account-links.php:159
msgid "Install WooCommerce"
msgstr "نصب ووکامرس"

#. Author of the plugin
msgid "MohammadJafar Khajeh"
msgstr "محمدجعفر خواجه"

#. Name of the plugin
#: Includes/Admin.php:69 Includes/Admin.php:70 Includes/Admin.php:388
msgid "My Account Links"
msgstr "لینک‌های حساب کاربری"

#: Includes/Admin.php:443
msgid ""
"No WooCommerce My Account menu items found. Make sure WooCommerce is fully "
"configured."
msgstr ""
"هیچ لینکی در منو حساب کاربری یافت نشد. لطفا تنظیمات ووکامرس را بررسی کنید."

#. Description of the plugin
msgid "Remove, rename, and reorder WooCommerce My Account navigation links."
msgstr "حذف، تغییر نام و مرتب‌سازی لینک‌های منوی حساب کاربری ووکامرس."

